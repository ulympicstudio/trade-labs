# ═══════════════════════════════════════════════════════════════════════
# Ulympic Trade Studio (UTS) — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy to .env and fill in values.  Defaults shown in comments.

# ── IB Gateway / TWS connection ──────────────────────────────────────
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# Per-arm client IDs (must be unique to avoid TWS disconnects)
TL_SIGNAL_IB_CLIENT_ID=2
TL_EXEC_IB_CLIENT_ID=3
TL_MONITOR_IB_CLIENT_ID=4

# ── Trade mode & safety ─────────────────────────────────────────────
TRADE_LABS_MODE=PAPER            # PAPER | LIVE (LIVE is hard-blocked)
TRADE_LABS_BACKEND=SIM           # SIM | IB
TRADE_LABS_ARMED=0               # 0 = dry-run, 1 = submit orders to IB

# ── Scoring & signal ────────────────────────────────────────────────
TL_MIN_CATALYST_SCORE=60         # 0-100; candidates below this are rejected

# ── API keys ─────────────────────────────────────────────────────────
FINNHUB_API_KEY=
PERPLEXITY_API_KEY=
API_KEY=

# ── Redis bus ────────────────────────────────────────────────────────
TL_REDIS_URL=redis://localhost:6379/0

# ── Execution arm ───────────────────────────────────────────────────
EXECUTION_ENABLED=false
TL_LIVE_TRADING=0
TL_EXEC_SIM_FRICTION=true
TL_EXEC_SIM_DELAY_MS=250
TL_EXEC_SIM_SLIPPAGE_BPS=2
TL_EXEC_SIM_PARTIAL_FILL_PCT=0.6
TL_EXEC_SLIPPAGE_MULT=0.05
TL_EXEC_SANDBOX_MAX_SPREAD_BPS=25.0
TL_EXEC_FORCE_PAPER_FILL=false

# ── Risk / kill-switch ──────────────────────────────────────────────
TL_ACCOUNT_EQUITY=100000
TL_KILL_ATR_SPIKE_MULT=2.5
TL_KILL_ATR_SPIKE_ACTION=REDUCE
TL_KS_STATE_PATH=data/kill_switch_state.json

# ── Sector limits ───────────────────────────────────────────────────
TL_RISK_MAX_ACTIVE_PER_SECTOR=3
TL_RISK_MAX_DRAFTS_PER_SECTOR=5
TL_RISK_MAX_ACTIVE_PER_INDUSTRY=2
TL_RISK_MAX_INDUSTRY_EXPOSURE=0.20
TL_RISK_SECTOR_EQUITY=100000

# ── Cash account ────────────────────────────────────────────────────
TL_CASH_FEES_BUFFER_USD=2.0
TL_CASH_STALE_THRESHOLD_S=120.0
TL_ACCOUNT_TYPE=

# ── Exit intelligence ───────────────────────────────────────────────
TL_EXIT_TIME_STOP_MR_S=1800
TL_EXIT_TIME_STOP_DEFAULT_S=7200
TL_EXIT_TIME_STOP_CHOP_S=2700
TL_EXIT_TIME_STOP_DEFENSIVE_S=1200
TL_EXIT_TRAIL_DEFAULT_PCT=1.5
TL_EXIT_TRAIL_TIGHT_PCT=0.8
TL_EXIT_TRAIL_LOOSE_PCT=2.5
TL_EXIT_TRIM_25_R=2.0
TL_EXIT_TRIM_50_R=3.5
TL_EXIT_SC_STRONG=1.10
TL_EXIT_SC_WEAK=0.90

# ── Ingest arm / news ──────────────────────────────────────────────
TL_NEWS_ENABLE_FINNHUB=false
TL_INGEST_USE_IB=0
TL_INGEST_NEWS_DAYS=1
TL_INGEST_NEWS_INTERVAL_S=20
TL_INGEST_INTERVAL_S=10

# ── Session policy ──────────────────────────────────────────────────
TL_POLICY_MAX_QUOTE_AGE_S=5.0

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/trade.db
